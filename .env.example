# Agency Platform — Environment Variables
# Copy to .env in each module directory and fill in values.

# ─── GitHub ──────────────────────────────────────────
GITHUB_TOKEN=ghp_...

# ─── Vercel ──────────────────────────────────────────
VERCEL_TOKEN=...
VERCEL_ORG_ID=...
VERCEL_PROJECT_ID=...

# ─── Twilio (Voice Agent) ────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...

# ─── Vapi (Voice Agent AI) ───────────────────────────
VAPI_API_KEY=...

# ─── Google My Business (Review Engine) ──────────────
GMB_CLIENT_ID=...
GMB_CLIENT_SECRET=...
GMB_REFRESH_TOKEN=...
GMB_ACCOUNT_ID=...
GMB_LOCATION_ID=...

# ─── OpenAI (Review Engine + Content Machine) ────────
OPENAI_API_KEY=sk-...

# ─── Supabase (Chat Widget Backend) ──────────────────
SUPABASE_URL=https://...supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── cal.diy (Booking Calendar) ──────────────────────
CALDIY_API_URL=https://cal.diy/api/v1
CALDIY_API_KEY=...

# ─── Discord Webhooks ────────────────────────────────
DISCORD_MONITORING_WEBHOOK=https://discord.com/api/webhooks/...
DISCORD_ALERTS_WEBHOOK=https://discord.com/api/webhooks/...

# ─── Hermes Cron ─────────────────────────────────────
# Cron jobs are managed via `hermes cron` CLI. See agency-platform/README.md
